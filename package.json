{
  "name": "ice-ssg",
  "version": "0.1.0",
  "description": "A static site generator powered by Bun, Droplet, and Markdown",
  "type": "module",
  "bin": {
    "ice": "./src/cli/index.ts"
  },
  "scripts": {
    "postinstall": "bun run scripts/patch-droplet.ts",
    "build": "bun run src/cli/index.ts build",
    "serve": "bun run src/cli/index.ts serve",
    "test": "bun test",
    "typecheck": "bun x tsc --noEmit"
  },
  "dependencies": {
    "droplet": "github:shayarnett/droplet",
    "markdown-it": "^14.1.0",
    "shiki": "^1.24.0",
    "gray-matter": "^4.0.3",
    "yaml": "^2.6.0"
  },
  "devDependencies": {
    "@types/markdown-it": "^14.1.2",
    "bun-types": "^1.3.10",
    "typescript": "^5.7.0"
  }
}
