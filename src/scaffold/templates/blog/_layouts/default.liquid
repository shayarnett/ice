<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{% if page.title %}{{ page.title }} - {% endif %}{{ site.title }}</title>
  <link rel="stylesheet" href="{{ site.baseUrl }}assets/css/main.css">
  <link rel="alternate" type="application/atom+xml" title="{{ site.title }}" href="{{ site.baseUrl }}feed.xml">
</head>
<body>
  <header>
    <nav>
      <a href="{{ site.baseUrl }}" class="site-title">{{ site.title }}</a>
      <ul>
        <li><a href="{{ site.baseUrl }}">Home</a></li>
        <li><a href="{{ site.baseUrl }}about/">About</a></li>
      </ul>
    </nav>
  </header>

  <main>
    {{ content }}
  </main>

  <footer>
    <p>&copy; {{ "now" | date: "%Y" }} {{ site.title }}. Built with <a href="https://github.com/example/ice">Ice</a>.</p>
  </footer>

  <script>
  (function() {
    var ws = new WebSocket("ws://" + location.host + "/__livereload");
    ws.onmessage = function(e) { if (e.data === "reload") location.reload(); };
    ws.onclose = function() { setTimeout(function() { location.reload(); }, 1000); };
  })();
  </script>
</body>
</html>
