<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{% if page.data.title %}{{ page.data.title }} - {% endif %}{{ site.title }}</title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
      color: #333; line-height: 1.6; display: flex; min-height: 100vh;
    }
    nav.sidebar {
      width: 250px; padding: 2rem 1rem; background: #f8f8f8;
      border-right: 1px solid #eee; flex-shrink: 0;
    }
    nav.sidebar h2 { font-size: 1.1rem; margin-bottom: 1rem; }
    nav.sidebar ul { list-style: none; }
    nav.sidebar li { margin-bottom: 0.5rem; }
    nav.sidebar a { color: #0066cc; text-decoration: none; }
    nav.sidebar a:hover { text-decoration: underline; }
    main { flex: 1; padding: 2rem 3rem; max-width: 50rem; }
    h1 { font-size: 2rem; margin-bottom: 1rem; }
    h2 { font-size: 1.5rem; margin: 1.5em 0 0.5em; }
    p { margin-bottom: 1em; }
    pre { background: #f5f5f5; padding: 1rem; border-radius: 4px; overflow-x: auto; margin-bottom: 1em; }
    code { background: #f5f5f5; padding: 0.15em 0.3em; border-radius: 3px; font-size: 0.9em; }
    pre code { background: none; padding: 0; }
  </style>
</head>
<body>
  <nav class="sidebar">
    <h2>{{ site.title }}</h2>
    <ul>
      <li><a href="{{ site.baseUrl }}">Home</a></li>
      <li><a href="{{ site.baseUrl }}getting-started/">Getting Started</a></li>
      <li><a href="{{ site.baseUrl }}configuration/">Configuration</a></li>
      <li><a href="{{ site.baseUrl }}deployment/">Deployment</a></li>
    </ul>
  </nav>
  <main>
    {{ content }}
  </main>
</body>
</html>
